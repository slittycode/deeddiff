{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the deeddiff main window: open files, run the bundled liteparse sidecar, emit progress events.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/lit",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
