    "test:watch": "vitest",
    "tauri": "tauri",
    "compare": "tsx scripts/compare.ts",
    "make-fixtures": "tsx scripts/make-fixtures.ts",
    "copy-wasm": "tsx scripts/copy-wasm.ts"
  },
  "dependencies": {
    "@llamaindex/liteparse": "2.0.5",
    "@tauri-apps/api": "^2.1.1",
