{
  "name": "deeddiff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first desktop tool to redline two versions of an agreement and explain each change in plain English. No cloud calls.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
